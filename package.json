		"sveltekit-superforms": "^2.20.1",
		"tailwind-merge": "^2.5.4",
		"tailwind-variants": "^0.3.0",
		"tailwindcss": "^3.4.15",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3",
		"vite": "^5.0.0",
		"vite-tsconfig-paths": "^5.1.3",
		"vitest": "^2.1.5",
		"zenstack": "2.9.0",
		"zod": "^3.23.8"
