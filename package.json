		"@node-rs/argon2": "^1.7.2",
		"@prisma/client": "^5.22.0",
		"@stripe/stripe-js": "^4.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@types/chart.js": "^2.9.41",
