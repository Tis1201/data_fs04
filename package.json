		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-node": "^2.1.2",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/uuid": "^10.0.0",
		"@vitest/coverage-v8": "^2.1.5",
		"@vitest/ui": "^2.1.5",
		"archiver": "^7.0.1",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^0.22.0",
		"clsx": "^2.1.1",
		"cmdk-sv": "^0.0.18",
		"concurrently": "^8.2.2",
