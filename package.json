{
	"name": "fs-web-app",
	"version": "0.0.1",
	"type": "module",
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"scripts": {
		"dev": "dotenv -- vite dev",
		"build": "dotenv -- vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "dotenv -- vitest run",
		"test:watch": "dotenv -- vitest",
		"test:ui": "dotenv -- vitest --ui",
		"test:coverage": "dotenv -- vitest run --coverage",
		"test:e2e": "playwright test tests/e2e/signup.test.ts",
		"build:prod": "npm run check && npm run lint && npm run test && npm run build",
		"preview:prod": "npm run build && npm run preview",
		"start": "node index.js",
		"db:setup": "node scripts/setup-db.js",
		"db:grant-createdb": "node scripts/grant-createdb.js",
		"db:seed": "prisma db seed",
		"db:setup-auth": "tsx scripts/setup-auth-tables.ts",
		"db:clear": "tsx scripts/clear-db.ts",
		"db:clear:dry-run": "tsx scripts/clear-db.ts --dry-run",
		"db:reset": "npm run db:clear && npm run seed:all",
		"seed": "tsx scripts/seed-admin.ts",
		"seed:all": "tsx scripts/seed-all.ts",
		"seed:users": "tsx scripts/seed-users.ts",
		"seed:groups": "tsx scripts/seed-groups-permissions.ts",
		"seed:test-data": "tsx scripts/seed-test-data.ts",
		"seed:plans": "tsx scripts/seed-plans.ts",
		"seed:pin-rules": "tsx scripts/seed-pin-rules.ts",
		"seed:radar-logs": "dotenv -- tsx scripts/seed-radar-logs.ts",
		"maildev": "maildev --smtp 1025 --web 1080",
		"dev:all": "concurrently \"npm run dev\" \"npm run maildev\"",
		"start:socket": "node socket.js",
		"preview:dev": "vite preview",
		"start:prod": "NODE_ENV=production dotenv -- node build",
		"prodServer": "NODE_ENV=production dotenv -- node prodServer.js",
		"package": "npm run build && node scripts/build/package-app.js",
		"process:main": "dotenv -- tsx scripts/processes/main-process.ts",
		"bundle:process": "dotenv -- tsx scripts/processes/bundle-process.ts",
		"mqtt:worker": "dotenv -- tsx src/worker/mqtt/index.ts",
		"mqtt:load": "dotenv -- tsx tests/mqtt/load-test.ts",
		"job:worker": "dotenv -- tsx src/worker/jobs/index.ts",
		"gcloud:cleanup": "dotenv -- tsx scripts/processes/gcloud-cleanup.ts",
		"dev:all-processes": "concurrently \"npm run dev\" \"npm run bundle:process\" \"npm run gcloud:cleanup\""
	},
	"devDependencies": {
		"@faker-js/faker": "^9.2.0",
		"@internationalized/date": "^3.8.1",
		"@lucia-auth/adapter-prisma": "^4.0.1",
		"@playwright/test": "^1.49.0",
		"@prisma/client": "^5.22.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-node": "^2.1.2",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/fs-extra": "^11.0.4",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/three": "^0.182.0",
		"@types/uuid": "^10.0.0",
		"@vitest/coverage-v8": "^2.1.5",
		"@vitest/ui": "^2.1.5",
		"archiver": "^7.0.1",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^0.22.0",
		"clsx": "^2.1.1",
		"cmdk-sv": "^0.0.18",
		"concurrently": "^8.2.2",
		"dotenv-cli": "^10.0.0",
		"eventsource": "^4.0.0",
		"formsnap": "^1.0.1",
		"fs-extra": "^11.3.0",
		"maildev": "^2.1.0",
		"postcss": "^8.4.49",
		"prisma": "^5.22.0",
		"svelte": "^4.2.19",
		"svelte-check": "^3.6.0",
		"sveltekit-superforms": "2.27.1",
		"tailwind-merge": "^2.5.4",
		"tailwind-variants": "^0.3.0",
		"tailwindcss": "^3.4.15",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3",
		"vite": "^5.0.0",
		"vite-tsconfig-paths": "^5.1.3",
		"vitest": "^2.1.5",
		"zenstack": "2.9.0",
		"zod": "^3.23.8"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1006.0",
		"@aws-sdk/s3-request-presigner": "^3.1006.0",
		"@battlefieldduck/xterm-svelte": "^1.0.1",
		"@clickhouse/client": "^1.12.1",
		"@dnd-kit/core": "^6.1.0",
		"@dnd-kit/sortable": "^8.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@google-cloud/storage": "^7.16.0",
		"@lucia-auth/adapter-postgresql": "^3.1.2",
		"@lucia-auth/adapter-prisma": "^4.0.0",
		"@microsoft/fetch-event-source": "^2.0.1",
		"@node-rs/argon2": "^1.7.2",
		"@prisma/client": "^5.22.0",
		"@stripe/stripe-js": "^4.0.0",
		"@superset-ui/embedded-sdk": "^0.2.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@types/chart.js": "^2.9.41",
		"@types/jszip": "^3.4.0",
		"@types/lodash": "^4.17.13",
		"@types/nodemailer": "^6.4.16",
		"@types/unzipper": "^0.10.11",
		"@whiskeysockets/baileys": "6.7.18",
		"@xterm/xterm": "^5.3.0",
		"@zenstackhq/runtime": "2.9.0",
		"app-info-parser": "^1.1.6",
		"arctic": "^3.1.3",
		"baileys": "^6.7.18",
		"bullmq": "^5.66.2",
		"chart.js": "^4.4.6",
		"class-variance-authority": "^0.7.0",
		"croner": "^9.1.0",
		"dotenv": "^16.4.5",
		"generate-password": "^1.7.1",
		"ioredis": "^5.7.0",
		"json-stringify-safe": "^5.0.1",
		"jsonwebtoken": "^9.0.2",
		"jszip": "^3.10.1",
		"konva": "^9.3.18",
		"label": "^0.2.2",
		"libphonenumber-js": "^1.11.14",
		"lodash": "^4.17.21",
		"lodash-es": "^4.17.21",
		"lucia": "^3.0.1",
		"lucide-svelte": "^0.460.1",
		"mode-watcher": "^0.4.1",
		"mqtt": "^5.14.1",
		"node-apk": "^1.2.1",
		"node-cache": "^5.1.2",
		"nodemailer": "^6.9.16",
		"p-limit": "^7.3.0",
		"pg": "^8.13.1",
		"pino": "^9.6.0",
		"prismjs": "^1.29.0",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"redis": "^5.8.2",
		"redlock": "^5.0.0-beta.2",
		"resend": "^4.5.1",
		"sharp": "^0.32.6",
		"socket.io-client": "^4.7.4",
		"sqlite3": "^5.1.2",
		"stripe": "^17.5.0",
		"svelte-headless-table": "^0.18.3",
		"svelte-konva": "^0.3.1",
		"svelte-persisted-store": "^0.12.0",
		"svelte-sonner": "^0.3.17",
		"svelte-stripe": "^1.3.0",
		"sveltekit-sse": "^0.13.9",
		"systeminformation": "^5.26.1",
		"tailwindcss-animate": "^1.0.7",
		"three": "^0.182.0",
		"ts-node": "^10.9.2",
		"unzipper": "^0.12.3",
		"uuid": "^13.0.0",
		"winston": "^3.17.0"
	}
}
