{
	"name": "fs-web-app",
	"version": "0.0.1",
	"type": "module",
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test tests/e2e/signup.test.ts",
		"build:prod": "npm run check && npm run lint && npm run test && npm run build",
		"preview:prod": "npm run build && npm run preview",
		"start": "node index.js",
		"db:setup": "node scripts/setup-db.js",
		"db:grant-createdb": "node scripts/grant-createdb.js",
		"db:seed": "prisma db seed",
		"db:setup-auth": "tsx scripts/setup-auth-tables.ts",
		"seed": "tsx scripts/seed-admin.ts",
		"seed:all": "tsx scripts/seed-all.ts",
		"maildev": "maildev --smtp 1025 --web 1080",
		"dev:all": "concurrently \"npm run dev\" \"npm run maildev\"",
		"start:socket": "node socket.js",
		"preview:dev": "vite preview",
		"start:prod": "NODE_ENV=production node build",
		"prodServer": "NODE_ENV=production node prodServer.js",
		"package": "npm run build && node scripts/build/package-app.js"
	},
	"devDependencies": {
		"@faker-js/faker": "^9.2.0",
		"@internationalized/date": "^3.8.1",
