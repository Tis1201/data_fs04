datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id() @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt()
  email            String            @unique()
  password         String
  rolesString      String            @default("")
  systemRole       String            @default("USER")
  sessions         Session[]
  keys             Key[]
  apiKeys          ApiKey[]
  whatsappAccounts WhatsAppAccount[]
}

model Session {
  id        String   @id()
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([userId])
}

model Key {
  id             String  @id()
  hashedPassword String? @map("hashed_password")
  userId         String  @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id          String    @id() @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()
  key         String    @unique()
  name        String
  description String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model WhatsAppAccount {
  id            String   @id() @default(cuid())
  client_id     String   @unique()
  client_status String   @default("disconnected")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt()
  phoneNumber   String
  name          String?
  description   String
  createdBy     String
  user          User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
}
