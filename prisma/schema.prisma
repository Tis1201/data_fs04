datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String             @id() @default(cuid())
  name             String?
  status           String             @default("ACTIVE")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt()
  email            String             @unique()
  password         String
  rolesString      String             @default("")
  systemRole       String             @default("USER")
  sessions         Session[]
  keys             Key[]
  apiKeys          ApiKey[]
  whatsappAccounts WhatsAppAccount[]
  listeners        ListenerEndpoint[]
  devices          Device[]
}

model Session {
  id        String   @id()
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([userId])
}

model Key {
  id             String  @id()
  hashedPassword String? @map("hashed_password")
  userId         String  @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id          String    @id() @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()
  key         String    @unique()
  name        String
  description String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

model WebhookEndPoint {
  id            String                    @id() @default(cuid())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt()
  postfix       String
  name          String
  description   String?
  active        Boolean                   @default(true)
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  createdBy     String
  hourlyMetrics WebhookHourlyMetric[]
  status        String                    @default("ACTIVE")
  listeners     ListenerWebhookEndpoint[]

  @@index([name])
  @@index([description])
}

model WebhookHourlyMetric {
  id        String          @id() @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt()
  webhookId String
  webhook   WebhookEndPoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  count     Int             @default(0)
  hourOfDay DateTime        @default(now())

  @@unique([webhookId, hourOfDay])
}

model ListenerEndpoint {
  id               String                    @id() @default(cuid())
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt()
  name             String
  description      String?
  postfix          String
  status           String                    @default("ACTIVE")
  expiresAt        DateTime?
  lastSeenAt       DateTime                  @default(now())
  userId           String
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEndpoints ListenerWebhookEndpoint[]
  whatsappAccounts ListenerWhatsAppAccount[]
  listenToAll      Boolean                   @default(true)

  @@index([userId])
}

model ListenerWebhookEndpoint {
  id                String           @id() @default(cuid())
  listenerId        String
  listener          ListenerEndpoint @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  webhookEndpointId String
  webhookEndpoint   WebhookEndPoint  @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([listenerId, webhookEndpointId])
}

model ListenerWhatsAppAccount {
  id                String           @id() @default(cuid())
  listenerId        String
  listener          ListenerEndpoint @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  whatsappAccountId String
  whatsappAccount   WhatsAppAccount  @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([listenerId, whatsappAccountId])
}

model WhatsAppAccount {
  id            String                    @id() @default(cuid())
  client_id     String                    @unique()
  client_status String                    @default("disconnected")
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt()
  phoneNumber   String
  name          String?
  description   String
  createdBy     String
  user          User                      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  listeners     ListenerWhatsAppAccount[]

  @@index([createdBy])
}

model WhatsAppAuthData {
  id        String   @id() @default(cuid())
  clientId  String
  keyId     String
  type      String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@unique([clientId, keyId])
  @@index([type])
  @@index([clientId])
}

model Device {
  id              String    @id() @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt()
  name            String
  description     String?
  status          String    @default("ACTIVE")
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  createdBy       String
  user            User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  deviceType      String?
  model           String?
  manufacturer    String?
  osVersion       String?
  firmwareVersion String?
  hardwareId      String?
  wifiMac         String?
  lanMac          String?
  ipAddress       String?
  apiKey          String?   @unique()
  apiKeyCreatedAt DateTime?
  apiKeyRotatedAt DateTime?
  claimedAt       DateTime?
  claimedBy       String?
  connected       Boolean   @default(false)
  connectedAt     DateTime?
  disconnectedAt  DateTime?

  @@index([createdBy])
  @@index([hardwareId])
  @@index([status])
}
