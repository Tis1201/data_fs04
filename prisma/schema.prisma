  error             String?
  metadata          Json?
  session           BundleInstallSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  batch             BundleInstallBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  device            Device                @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  bundles           BundleInstallBundle[]

  @@index([sessionId])
  @@index([batchId])
  @@index([deviceId])
  @@index([status])
}

model BundleInstallBundle {
  id          String               @id() @default(cuid())
  sessionId   String
  batchId     String
  deviceId    String
  bundleId    String
  status      String               @default("PENDING")
  progress    Int                  @default(0)
  message     String?
  error       String?
  initiatedAt DateTime             @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?
  metadata    Json?
  session     BundleInstallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  batch       BundleInstallBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  device      BundleInstallDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  bundle      Bundle               @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([batchId])
  @@index([deviceId])
  @@index([bundleId])
  @@index([status])
}

model BundleInstallError {
  id           String               @id() @default(cuid())
  sessionId    String
  batchId      String?
  deviceId     String?
  bundleId     String?
  errorType    String
  errorCode    String
  errorMessage String
  retryCount   Int                  @default(0)
  maxRetries   Int                  @default(3)
  timestamp    DateTime             @default(now())
  metadata     Json?
  session      BundleInstallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([batchId])
  @@index([deviceId])
  @@index([bundleId])
  @@index([errorType])
  @@index([timestamp])
}

model License {
  id           String           @id() @default(cuid())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt()
  createdBy    String
  updatedBy    String
  description  String?
  accountId    String
  account      Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  deviceId     String?
  device       Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  status       String           @default("ACTIVE")
  issuedAt     DateTime         @default(now())
  expiresAt    DateTime
  jwt          String
  keyId        String
  algorithm    String           @default("RS256")
  signingKeyId String
  signingKey   JwtSigningKey    @relation(fields: [signingKeyId], references: [id])
  renewals     LicenseRenewal[]
  entitlements Entitlement[]

  @@unique([accountId, deviceId, status])
  @@index([accountId])
  @@index([deviceId])
  @@index([status])
  @@index([signingKeyId])
}

model LicenseRenewal {
  id            String    @id() @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt()
  createdBy     String
  updatedBy     String
  licenseId     String
  license       License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  oldIssuedAt   DateTime?
  oldExpiresAt  DateTime?
  newIssuedAt   DateTime
  newExpiresAt  DateTime
  jwtSnapshot   String
  source        String
  transactionId String?
  metadata      String?
  performedBy   String?

  @@index([licenseId])
  @@index([transactionId])
}

model Entitlement {
  id        String    @id() @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
  createdBy String
  updatedBy String
  code      String
  value     String?
  metadata  String?
  status    String    @default("ACTIVE")
  startsAt  DateTime?
  endsAt    DateTime?
  accountId String?
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  licenseId String?
  license   License?  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, code])
  @@unique([accountId, code])
  @@index([accountId])
  @@index([licenseId])
  @@index([status])
}

model PreclaimSet {
  id          String           @id() @default(cuid())
  name        String
  description String?
  status      SetStatus        @default(ACTIVE)
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt()
  createdBy   String
  accountId   String
  account     Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  claims      PreclaimDevice[]

  @@unique([accountId, name])
  @@index([accountId])
  @@index([status])
  @@index([expiresAt])
}

model PreclaimDevice {
  id          String      @id() @default(cuid())
  macId       String
  name        String?
  description String?
  status      ClaimStatus @default(PENDING)
  expiresAt   DateTime?
  claimedAt   DateTime?
  claimedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt()
  accountId   String
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  setId       String
  set         PreclaimSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  deviceId    String?
  device      Device?     @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([setId, macId])
  @@index([macId])
  @@index([status])
  @@index([expiresAt])
  @@index([accountId])
}

model DeviceProfile {
  id          String                    @id() @default(cuid())
  name        String
  description String?
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt()
  createdBy   String
  updatedBy   String?
  accountId   String
  account     Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  settings    DeviceProfileSetting[]
  assignments DeviceProfileAssignment[]

  @@index([accountId])
  @@index([createdBy])
}

model DeviceProfileSetting {
  id        String        @id() @default(cuid())
  profileId String
  profile   DeviceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  key       String
  value     String
  dataType  String
  label     String
  category  String?
  order     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt()

  @@unique([profileId, key])
  @@index([profileId])
}

model DeviceProfileAssignment {
  id         String        @id() @default(cuid())
  profileId  String
  deviceId   String
  profile    DeviceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  device     Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  assignedAt DateTime      @default(now())
  assignedBy String
  status     String        @default("ACTIVE")
  appliedAt  DateTime?
  lastSyncAt DateTime?

  @@unique([deviceId])
  @@index([profileId])
  @@index([deviceId])
}

model DeviceAppSummary {
  id              String    @id() @default(cuid())
  deviceId        String    @unique()
  accountId       String
  totalAppsCount  Int       @default(0)
  systemAppsCount Int       @default(0)
  normalAppsCount Int       @default(0)
  lastAppSync     DateTime?
  lastProcessedAt DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt()
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([accountId])
  @@index([lastProcessedAt])
}

model PinRule {
  id            String          @id() @default(cuid())
  ruleType      String
  createdBy     String
  accountId     String?
  name          String
  description   String?
  apps          String[]
  targetType    String?
  targetValue   String[]
  priority      Int
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt()
  createdByUser User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  account       Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  userActions   UserAppAction[]

  @@index([ruleType])
  @@index([accountId])
  @@index([createdBy])
  @@index([priority])
  @@index([isActive])
}

model UserAppAction {
  id          String   @id() @default(cuid())
  userId      String
  deviceId    String
  action      String
  packageName String
  ruleId      String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  rule        PinRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
  @@index([action])
  @@index([createdAt])
}

model MqttConnection {
  clientId       String    @id()
  username       String
  kind           String
  status         String    @default("CONNECTED")
  connectedAt    DateTime  @default(now())
  disconnectedAt DateTime?
  lastEventAt    DateTime  @default(now())
  node           String?
  reason         String?

  @@index([username])
  @@index([status])
  @@index([lastEventAt])
}

model Controller {
  id           String   @id() @default(cuid())
  name         String
  type         String
  serialNumber String   @unique()
  status       String   @default("INACTIVE")
  isDeleted    Boolean  @default(false)
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  createdBy    String?
  creator      User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  description  String?
  sensors      Sensor[]

  @@index([accountId])
  @@index([deviceId])
  @@index([type])
  @@index([status])
}

model Sensor {
  id            String     @id() @default(cuid())
  name          String
  type          String
  serialNumber  String     @unique()
  status        String     @default("INACTIVE")
  controllerId  String
  controller    Controller @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt()
  createdBy     String?
  creator       User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  description   String?
  location      String?
  firmware      String?
  config        Json?
  configVersion Int        @default(0)
  syncStatus    String     @default("SYNCED")
  lastSyncedAt  DateTime?
  lastSyncError String?

  @@index([controllerId])
  @@index([accountId])
  @@index([type])
  @@index([status])
}
