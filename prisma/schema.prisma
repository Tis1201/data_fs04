  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members     GroupMembership[]

  @@unique([accountId, name])
  @@index([accountId])
}

model GroupMembership {
  id           String            @id() @default(cuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt()
  groupId      String
  group        Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  membershipId String
  membership   AccountMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([groupId, membershipId])
  @@index([groupId])
  @@index([membershipId])
}

model Permission {
  id        String   @id() @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  module    String
  action    String
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@unique([groupId, module, action])
  @@index([groupId])
  @@index([module, action])
}

model User {
  id                 String              @id() @default(cuid())
  name               String?
  status             String              @default("ACTIVE")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt()
  email              String              @unique()
  password           String
  rolesString        String              @default("")
  systemRole         String              @default("USER")
  primaryAccountId   String?
  sessions           Session[]
  keys               Key[]
  apiKeys            ApiKey[]
  whatsappAccounts   WhatsAppAccount[]
  listeners          ListenerEndpoint[]
  devices            Device[]
  accountMemberships AccountMembership[]
  primaryAccount     Account?            @relation("UserPrimaryAccount", fields: [primaryAccountId], references: [id], onDelete: SetNull)
  invitationTokens   InvitationToken[]
  jwtSigningKeys     JwtSigningKey[]
  tokenUsageLogs     TokenUsageLog[]
  refreshTokens      RefreshToken[]

  @@index([primaryAccountId])
}

model Session {
