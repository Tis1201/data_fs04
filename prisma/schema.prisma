datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id             String              @id() @default(cuid())
  name           String
  slug           String              @unique()
  status         String              @default("ACTIVE")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt()
  description    String?
  logoUrl        String?
  settings       String?
  companies      Company[]
  members        AccountMembership[]
  groups         Group[]
  devices        Device[]
  apiKeys        ApiKey[]
  primaryUsers   User[]              @relation("UserPrimaryAccount")
  resources      Resource[]
  refreshTokens  RefreshToken[]
  tokenUsageLogs TokenUsageLog[]

  @@index([slug])
}

model Company {
  id           String   @id() @default(cuid())
  name         String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  description  String?
  address      String?
  contactEmail String?
  contactPhone String?
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  devices      Device[]

  @@index([accountId])
}

model AccountMembership {
  id               String            @id() @default(cuid())
  role             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt()
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  groupMemberships GroupMembership[]

  @@unique([userId, accountId])
  @@index([userId])
  @@index([accountId])
}

model Group {
  id          String            @id() @default(cuid())
  name        String
