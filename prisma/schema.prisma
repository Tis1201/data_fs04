datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id             String              @id() @default(cuid())
  name           String
  slug           String              @unique()
  status         String              @default("ACTIVE")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt()
  description    String?
  logoUrl        String?
  settings       String?
  companies      Company[]
  members        AccountMembership[]
  groups         Group[]
  devices        Device[]
  apiKeys        ApiKey[]
  primaryUsers   User[]              @relation("UserPrimaryAccount")
  resources      Resource[]
  refreshTokens  RefreshToken[]
  tokenUsageLogs TokenUsageLog[]

  @@index([slug])
}

model Company {
  id           String   @id() @default(cuid())
  name         String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
  description  String?
  address      String?
  contactEmail String?
  contactPhone String?
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  devices      Device[]

  @@index([accountId])
}

model AccountMembership {
  id               String            @id() @default(cuid())
  role             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt()
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  groupMemberships GroupMembership[]

  @@unique([userId, accountId])
  @@index([userId])
  @@index([accountId])
}

model Group {
  id          String            @id() @default(cuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt()
  permissions String
  accountId   String
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members     GroupMembership[]

  @@unique([accountId, name])
  @@index([accountId])
}

model GroupMembership {
  id           String            @id() @default(cuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt()
  groupId      String
  group        Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  membershipId String
  membership   AccountMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([groupId, membershipId])
  @@index([groupId])
  @@index([membershipId])
}

model User {
  id                 String              @id() @default(cuid())
  name               String?
  status             String              @default("ACTIVE")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt()
  email              String              @unique()
  password           String
  rolesString        String              @default("")
  systemRole         String              @default("USER")
  primaryAccountId   String?
  sessions           Session[]
  keys               Key[]
  apiKeys            ApiKey[]
  whatsappAccounts   WhatsAppAccount[]
  listeners          ListenerEndpoint[]
  devices            Device[]
  accountMemberships AccountMembership[]
  primaryAccount     Account?            @relation("UserPrimaryAccount", fields: [primaryAccountId], references: [id], onDelete: SetNull)
  invitationTokens   InvitationToken[]
  jwtSigningKeys     JwtSigningKey[]
  tokenUsageLogs     TokenUsageLog[]
  refreshTokens      RefreshToken[]

  @@index([primaryAccountId])
}

model Session {
  id        String   @id()
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([userId])
}

model Key {
  id             String  @id()
  hashedPassword String? @map("hashed_password")
  userId         String  @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id          String    @id() @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()
  key         String    @unique()
  name        String
  description String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([key])
  @@index([accountId])
}

model WebhookEndPoint {
  id            String                    @id() @default(cuid())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt()
  postfix       String
  name          String
  description   String?
  active        Boolean                   @default(true)
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  createdBy     String
  hourlyMetrics WebhookHourlyMetric[]
  status        String                    @default("ACTIVE")
  listeners     ListenerWebhookEndpoint[]

  @@index([name])
  @@index([description])
}

model WebhookHourlyMetric {
  id        String          @id() @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt()
  webhookId String
  webhook   WebhookEndPoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  count     Int             @default(0)
  hourOfDay DateTime        @default(now())

  @@unique([webhookId, hourOfDay])
}

model ListenerEndpoint {
  id               String                    @id() @default(cuid())
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt()
  name             String
  description      String?
  postfix          String
  status           String                    @default("ACTIVE")
  expiresAt        DateTime?
  lastSeenAt       DateTime                  @default(now())
  userId           String
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEndpoints ListenerWebhookEndpoint[]
  whatsappAccounts ListenerWhatsAppAccount[]
  listenToAll      Boolean                   @default(true)

  @@index([userId])
}

model ListenerWebhookEndpoint {
  id                String           @id() @default(cuid())
  listenerId        String
  listener          ListenerEndpoint @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  webhookEndpointId String
  webhookEndpoint   WebhookEndPoint  @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([listenerId, webhookEndpointId])
}

model ListenerWhatsAppAccount {
  id                String           @id() @default(cuid())
  listenerId        String
  listener          ListenerEndpoint @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  whatsappAccountId String
  whatsappAccount   WhatsAppAccount  @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([listenerId, whatsappAccountId])
}

model WhatsAppAccount {
  id            String                    @id() @default(cuid())
  client_id     String                    @unique()
  client_status String                    @default("disconnected")
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt()
  phoneNumber   String
  name          String?
  description   String
  createdBy     String
  user          User                      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  listeners     ListenerWhatsAppAccount[]

  @@index([createdBy])
}

model WhatsAppAuthData {
  id        String   @id() @default(cuid())
  clientId  String
  keyId     String
  type      String
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@unique([clientId, keyId])
  @@index([type])
  @@index([clientId])
}

model Device {
  id              String         @id() @default(cuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt()
  name            String
  factoryTokens   FactoryToken[]
  description     String?
  status          String         @default("ACTIVE")
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  createdBy       String
  user            User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  accountId       String?
  account         Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deviceType      String?
  model           String?
  manufacturer    String?
  osVersion       String?
  firmwareVersion String?
  hardwareId      String?
  wifiMac         String?
  lanMac          String?
  ipAddress       String?
  apiKey          String?        @unique()
  apiKeyCreatedAt DateTime?
  apiKeyRotatedAt DateTime?
  claimedAt       DateTime?
  claimedBy       String?
  connected       Boolean        @default(false)
  connectedAt     DateTime?
  disconnectedAt  DateTime?

  @@index([createdBy])
  @@index([hardwareId])
  @@index([status])
  @@index([accountId])
  @@index([companyId])
}

model Setting {
  id        String   @id() @default(cuid())
  isActive  Boolean  @default(true)
  data      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  updatedBy String
  createdBy String

  @@index([isActive])
}

model EmailServiceProvider {
  id         String    @id() @default(cuid())
  name       String
  type       String
  isDefault  Boolean   @default(false)
  isActive   Boolean   @default(true)
  fromEmail  String
  fromName   String?
  smtpHost   String?
  smtpPort   Int?
  smtpUser   String?
  smtpPass   String?
  smtpSecure Boolean   @default(true)
  smtpAuth   Boolean   @default(true)
  apiKey     String?
  apiSecret  String?
  domain     String?
  region     String?
  webhookUrl String?
  webhookKey String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())
  createdBy  String
  updatedBy  String
  lastUsedAt DateTime?
  totalSent  Int       @default(0)
  status     String    @default("ACTIVE")

  @@index([isActive])
  @@index([isDefault])
  @@index([type])
}

model InvitationToken {
  id        String    @id() @default(cuid())
  token     String    @unique()
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
}

model Resource {
  id        String   @id() @default(cuid())
  name      String
  type      String
  path      String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  createdBy String
  updatedBy String
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])

  @@index([name])
  @@index([type])
  @@index([createdBy])
}

model JwtSigningKey {
  id          String    @id() @default(cuid())
  keyId       String
  keyType     String
  privateKey  String
  publicKey   String
  algorithm   String    @default("RS256")
  isActive    Boolean   @default(true)
  isPrimary   Boolean   @default(false)
  rotatedAt   DateTime?
  expiresAt   DateTime?
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()

  @@unique([keyType, keyId], map: "unique_key_id_per_type")
  @@index([keyType, isActive])
  @@index([expiresAt])
}

model FactoryToken {
  id              String    @id() @default(cuid())
  tokenId         String    @unique()
  serialNumber    String    @unique()
  hardwareModel   String
  firmwareVersion String
  batchNumber     String?
  isUsed          Boolean   @default(false)
  usedAt          DateTime?
  usedByIp        String?
  issuedAt        DateTime  @default(now())
  expiresAt       DateTime
  issuedBy        String
  notes           String?
  device          Device?   @relation(fields: [deviceId], references: [id])
  deviceId        String?

  @@index([serialNumber])
  @@index([isUsed])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id() @default(cuid())
  tokenHash String    @unique()
  deviceId  String?
  userAgent String?
  ipAddress String?
  account   Account   @relation(fields: [accountId], references: [id])
  accountId String
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  isRevoked Boolean   @default(false)
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([accountId])
  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model TokenUsageLog {
  id        String   @id() @default(cuid())
  tokenId   String?
  tokenType String
  action    String
  ipAddress String?
  userAgent String?
  account   Account? @relation(fields: [accountId], references: [id])
  accountId String?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  success   Boolean  @default(true)
  error     String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([userId])
  @@index([tokenId])
  @@index([createdAt])
}

model FailedLoginLog {
  id          String   @id() @default(cuid())
  email       String
  ipAddress   String?
  userAgent   String?
  reason      String
  attemptedAt DateTime @default(now())
  accountId   String?

  @@index([email])
  @@index([ipAddress])
  @@index([attemptedAt])
  @@index([accountId])
}

model UserSessionLog {
  id         String   @id() @default(cuid())
  action     String
  sessionId  String?
  ipAddress  String?
  userAgent  String?
  deviceInfo String?
  timestamp  DateTime @default(now())
  userId     String
  accountId  String?

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([sessionId])
  @@index([accountId])
}
